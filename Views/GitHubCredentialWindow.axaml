<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="VNEditor.Views.GitHubCredentialWindow"
        Title="GitHub 身份验证"
        Width="520"
        Height="380"
        MinHeight="320"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*" RowSpacing="10">
        <TextBlock Grid.Row="0" TextWrapping="Wrap" Opacity="0.9"
                   Text="HTTPS 远程需要验证身份。请使用 GitHub「Personal Access Token」作为密码（不要使用账户登录密码）。用户名可留空，将使用 x-access-token。"/>
        <TextBlock Grid.Row="1" x:Name="RemoteUrlText" TextWrapping="Wrap" FontSize="12" Opacity="0.75"/>
        <TextBlock Grid.Row="2" x:Name="ErrorHintText" TextWrapping="Wrap" Foreground="#FFB8860B" IsVisible="False"/>
        <StackPanel Grid.Row="3" Spacing="4">
            <TextBlock Text="用户名（可选）"/>
            <TextBox x:Name="UserNameBox" Watermark="GitHub 用户名，或留空"/>
        </StackPanel>
        <StackPanel Grid.Row="4" Spacing="4">
            <TextBlock Text="Personal Access Token"/>
            <TextBox x:Name="TokenBox" PasswordChar="●" Watermark="ghp_… 或 fine-grained token"/>
        </StackPanel>
        <TextBlock Grid.Row="5" x:Name="TokenLinkText" Text="打开 github.com/settings/tokens 创建令牌" TextDecorations="Underline"
                   Foreground="#FF569CD6" Cursor="Hand"/>
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Spacing="8">
            <Button x:Name="OkButton" Content="确定" MinWidth="88" IsDefault="True"/>
            <Button x:Name="CancelButton" Content="取消" MinWidth="88" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
